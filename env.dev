# === Common ===
BSLLMNER_VIEWER_PREFIX=bsllmner-viewer-dev
BSLLMNER_VIEWER_ENV=dev
TZ=Asia/Tokyo

# === App (Streamlit) ===
# APP_INTERNAL_PORT を変える場合は APP_COMMAND の --server.port も合わせて変更すること
BSLLMNER_VIEWER_APP_COMMAND=uv run streamlit run src/bsllmner_viewer/ui/Home.py --server.address=0.0.0.0 --server.port=8000 --server.headless=true
BSLLMNER_VIEWER_APP_PORT=8000
BSLLMNER_VIEWER_APP_INTERNAL_PORT=8000
BSLLMNER_VIEWER_LOG_LEVEL=debug

# === ETL / Data ===
BSLLMNER_VIEWER_DATA_DIR=/app/data
