PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>

# sh-ikeda/ontology-constructor-for-bsllmner CONSTRUCT queries do not emit
# `?s rdf:type owl:Class`, which makes `owlready2.ontology.classes()` return
# 0 on the resulting OWL. Applying this INSERT after the subset is built
# re-declares each labeled IRI as an owl:Class so owlready2 can load it.

INSERT {
  ?s rdf:type owl:Class .
}
WHERE {
  ?s rdfs:label ?label .
  FILTER (!isBlank(?s))
}
